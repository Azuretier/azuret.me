{
  "manifest_version": 3,
  "name": "Hybrid Notes Live Bridge",
  "version": "0.1.0",
  "description": "Send the current Microsoft Edge tab to Hybrid Notes Desktop in real time.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://127.0.0.1:4317/*", "http://localhost:4317/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Hybrid Notes Live Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
